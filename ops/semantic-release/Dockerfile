ARG IMAGE_VERSION=20.8.1-bookworm
FROM node:${IMAGE_VERSION}

WORKDIR /workspace

ARG SEMANTIC_RELEASE_VERSION=23.1.1
ENV SEMANTIC_RELEASE_VERSION=${SEMANTIC_RELEASE_VERSION}

ARG SEMANTIC_RELEASE_GITHUB_VERSION=10.3.5
ENV SEMANTIC_RELEASE_GITHUB_VERSION=${SEMANTIC_RELEASE_GITHUB_VERSION}

ARG SEMANTIC_RELEASE_GITHUB_PLUGINS=1.1.1
ENV SEMANTIC_RELEASE_GITHUB_PLUGINS=${SEMANTIC_RELEASE_GITHUB_PLUGINS}

ARG SEMANTIC_RELEASE_RELEASENOTESGENERATOR_VERSION=14.0.0
ENV SEMANTIC_RELEASE_RELEASENOTESGENERATOR_VERSION=${SEMANTIC_RELEASE_RELEASENOTESGENERATOR_VERSION}

ARG CONVENTIONAL_CHANGELOG_CONVENTIONALCOMMITS_VERSION=7.0.2
ENV CONVENTIONAL_CHANGELOG_CONVENTIONALCOMMITS_VERSION=${CONVENTIONAL_CHANGELOG_CONVENTIONALCOMMITS_VERSION}

ARG COMMITLINT_CONFIG_CONVENTIONAL_VERSION=19.2.2
ENV COMMITLINT_CONFIG_CONVENTIONAL_VERSION=${COMMITLINT_CONFIG_CONVENTIONAL_VERSION}

ARG RUN_VERSION=1.5.0
ENV RUN_VERSION=${RUN_VERSION}

RUN npm install -g semantic-release@${SEMANTIC_RELEASE_VERSION} && \
    npm install -g @semantic-release/github@${SEMANTIC_RELEASE_GITHUB_VERSION} && \
    npm install -g @semantic-release/release-notes-generator@${SEMANTIC_RELEASE_RELEASENOTESGENERATOR_VERSION} && \
    npm install -g conventional-changelog-conventionalcommits@${CONVENTIONAL_CHANGELOG_CONVENTIONALCOMMITS_VERSION} && \
    npm install -g @commitlint/config-conventional@${COMMITLINT_CONFIG_CONVENTIONAL_VERSION} && \
    npm install -g semantic-release-export-data@${SEMANTIC_RELEASE_GITHUB_PLUGINS} && \
    npm install -g run@${RUN_VERSION} && \
    apt-get update && \
    apt-get install --no-install-recommends -y jq && \
    apt-get autoremove -yqq --purge && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    rm -rf /tmp/* /var/tmp/*

CMD [ "npx", "run" ]
